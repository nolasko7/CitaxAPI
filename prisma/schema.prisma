generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CLIENTE {
  id_cliente           Int                    @id @default(autoincrement())
  id_empresa           Int
  whatsapp_id          String                 @db.VarChar(50)
  nombre_wa            String?                @db.VarChar(255)
  EMPRESA              EMPRESA                @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction, map: "fk_cliente_empresa")
  MENSAJE_CONVERSACION MENSAJE_CONVERSACION[]
  TURNO                TURNO[]

  @@unique([id_empresa, whatsapp_id], map: "id_empresa")
}

model CONFIG_WHATSAPP {
  id_whatsapp   Int      @id @default(autoincrement())
  id_empresa    Int      @unique(map: "id_empresa")
  instance_name String   @db.VarChar(255)
  apikey          String?  @db.VarChar(255)
  conectado       Boolean? @default(false)
  whatsapp_number String?  @db.VarChar(50)
  EMPRESA       EMPRESA  @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction, map: "fk_configwp_empresa")
}

model EMPRESA {
  id_empresa              Int              @id @default(autoincrement())
  id_usuario              Int
  nombre_comercial        String           @db.VarChar(255)
  slug                    String           @unique(map: "slug") @db.VarChar(100)
  direccion               String?          @db.Text
  horarios_disponibilidad Json?
  config_recordatorios    Json?
  CLIENTE                 CLIENTE[]
  CONFIG_WHATSAPP         CONFIG_WHATSAPP?
  USUARIO                 USUARIO          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_empresa_usuario")
  PRESTADOR               PRESTADOR[]
  SERVICIO                SERVICIO[]

  @@index([id_usuario], map: "fk_empresa_usuario")
}

model MENSAJE_CONVERSACION {
  id_mensaje Int       @id @default(autoincrement())
  id_cliente Int
  rol_emisor String    @db.VarChar(50)
  contenido  String    @db.Text
  fecha_hora DateTime? @default(now()) @db.DateTime(0)
  CLIENTE    CLIENTE   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction, map: "fk_mensaje_cliente")

  @@index([id_cliente], map: "fk_mensaje_cliente")
}

model PRESTADOR {
  id_prestador Int      @id @default(autoincrement())
  id_usuario   Int      @unique(map: "id_usuario")
  id_empresa   Int
  activo       Boolean? @default(true)
  horarios_disponibilidad Json?
  EMPRESA      EMPRESA  @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction, map: "fk_prestador_empresa")
  USUARIO      USUARIO              @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_prestador_usuario")
  TURNO        TURNO[]
  SERVICIOS    PRESTADOR_SERVICIO[]

  @@index([id_empresa], map: "fk_prestador_empresa")
}

model PRESTADOR_SERVICIO {
  id_prestador Int
  id_servicio  Int
  PRESTADOR    PRESTADOR @relation(fields: [id_prestador], references: [id_prestador], onDelete: Cascade, onUpdate: NoAction)
  SERVICIO     SERVICIO  @relation(fields: [id_servicio], references: [id_servicio], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_prestador, id_servicio])
}

model SERVICIO {
  id_servicio      Int     @id @default(autoincrement())
  id_empresa       Int
  nombre           String               @db.VarChar(255)
  descripcion      String?              @db.Text
  duracion_minutos Int
  precio           Decimal              @db.Decimal(10, 2)
  EMPRESA          EMPRESA              @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction, map: "fk_servicio_empresa")
  TURNO            TURNO[]
  PRESTADORES      PRESTADOR_SERVICIO[]

  @@index([id_empresa], map: "fk_servicio_empresa")
}

model TURNO {
  id_turno     Int       @id @default(autoincrement())
  id_cliente   Int
  id_prestador Int
  id_servicio  Int
  fecha_hora   DateTime  @db.DateTime(0)
  estado       String    @default("pendiente") @db.VarChar(50)
  CLIENTE      CLIENTE   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction, map: "fk_turno_cliente")
  PRESTADOR    PRESTADOR @relation(fields: [id_prestador], references: [id_prestador], onDelete: Cascade, onUpdate: NoAction, map: "fk_turno_prestador")
  SERVICIO     SERVICIO  @relation(fields: [id_servicio], references: [id_servicio], onDelete: Cascade, onUpdate: NoAction, map: "fk_turno_servicio")

  @@index([id_cliente], map: "fk_turno_cliente")
  @@index([id_prestador], map: "fk_turno_prestador")
  @@index([id_servicio], map: "fk_turno_servicio")
}

model USUARIO {
  id_usuario    Int        @id @default(autoincrement())
  email         String     @unique(map: "email") @db.VarChar(255)
  password_hash String     @db.VarChar(255)
  nombre        String     @db.VarChar(100)
  apellido      String     @db.VarChar(100)
  rol           String     @db.VarChar(50)
  created_at    DateTime?  @default(now()) @db.DateTime(0)
  EMPRESA       EMPRESA[]
  PRESTADOR     PRESTADOR?
}
